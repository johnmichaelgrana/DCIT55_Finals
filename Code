//Creates a virtual table that displays only laundry orders that are ready for pickup.
CREATE VIEW ReadyLaundry AS

SELECT
    LaundryID,
    CustomerID,
    Charge,
    Status

FROM Laundry

WHERE Status = 'Ready';

SELECT * FROM readylaundry;
DELIMITER $$


//Creates a reusable function that automatically calculates the laundry charge based on weight and rate per kilogram.
CREATE FUNCTION ComputeCharge(
    pWeight DECIMAL(5,2),
    pRate DECIMAL(5,2)
)

RETURNS DECIMAL(10,2)

DETERMINISTIC

BEGIN

    RETURN pWeight * pRate;

END $$

DELIMITER ;

SELECT ComputeCharge(8,35);

DELIMITER $$


//Creates a procedure that simplifies the process of recording a new laundry order and automatically computes the charge.
CREATE PROCEDURE ReceiveLaundry(
    IN pCustomerID INT,
    IN pWeight DECIMAL(5,2),
    IN pRate DECIMAL(5,2),
    IN pTicketNo VARCHAR(20)
)


//Computes the total charge based on weight and rate per kilo.
BEGIN

    DECLARE vCharge DECIMAL(10,2);

    SET vCharge = pWeight * pRate;


//Saves a new laundry order into the database.
    INSERT INTO Laundry(
        CustomerID,
        ClaimTicketNo,
        Weight,
        RatePerKilo,
        Charge,
        DateReceived,
        Status
    )

    VALUES(
        pCustomerID,
        pTicketNo,
        pWeight,
        pRate,
        vCharge,
        CURDATE(),
        'In Process'
    );

END $$

DELIMITER ;


//Changes the status of the laundry transaction.
