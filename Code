//Creates a new database named LaundryShopDB that will store all records related to the laundry management system.
CREATE DATABASE LaundryShopDB;

USE LaundryShopDB;


//Creates a table to store customer information such as their name and contact number. Each customer is assigned a unique ID.
CREATE TABLE Customer (
    CustomerID INT AUTO_INCREMENT PRIMARY KEY,
    CustomerName VARCHAR(100) NOT NULL,
    ContactNo VARCHAR(20)
);


//Creates a table that records laundry transactions, including the customer, weight of clothes, service charge, dates, and current status.
CREATE TABLE Laundry (
    LaundryID INT AUTO_INCREMENT PRIMARY KEY,
    CustomerID INT,
    Weight DECIMAL(5,2),
    RatePerKilo DECIMAL(5,2),
    Charge DECIMAL(10,2),
    DateReceived DATE,
    DateReady DATE,
    Status VARCHAR(20),

    FOREIGN KEY (CustomerID)
    REFERENCES Customer(CustomerID)
);


//Creates a table for storing payment records made for laundry services.
CREATE TABLE Payments (
    PaymentID INT AUTO_INCREMENT PRIMARY KEY,
    LaundryID INT,
    AmountPaid DECIMAL(10,2),
    PaymentDate DATE,

    FOREIGN KEY (LaundryID)
    REFERENCES Laundry(LaundryID)
);


