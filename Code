DELIMITER $$


//Automatically calculates the laundry charge when a new laundry record is added.
CREATE TRIGGER trg_UnclaimedLaundry


//Automatically marks ready laundry as unclaimed after 30 days
BEFORE UPDATE
ON Laundry

FOR EACH ROW

BEGIN

    IF OLD.Status = 'Ready'
       AND DATEDIFF(CURDATE(), OLD.DateReady) > 30
    THEN

        SET NEW.Status = 'Unclaimed';

    END IF;

END $$

DELIMITER ;
