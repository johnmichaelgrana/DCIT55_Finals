DELIMITER $$

CREATE TRIGGER trg_UnclaimedLaundry

BEFORE UPDATE
ON Laundry

FOR EACH ROW

BEGIN

    IF OLD.Status = 'Ready'
       AND DATEDIFF(CURDATE(), OLD.DateReady) > 30
    THEN

        SET NEW.Status = 'Unclaimed';

    END IF;

END $$

DELIMITER ;
