DELIMITER $$

CREATE FUNCTION ComputeCharge(
    pWeight DECIMAL(5,2),
    pRate DECIMAL(5,2)
)

RETURNS DECIMAL(10,2)

DETERMINISTIC

BEGIN

    RETURN pWeight * pRate;

END $$

DELIMITER ;

SELECT ComputeCharge(8,35);

DELIMITER $$


CREATE PROCEDURE ReceiveLaundry(
    IN pCustomerID INT,
    IN pWeight DECIMAL(5,2),
    IN pRate DECIMAL(5,2),
    IN pTicketNo VARCHAR(20)
)

BEGIN

    DECLARE vCharge DECIMAL(10,2);

    SET vCharge = pWeight * pRate;

    INSERT INTO Laundry(
        CustomerID,
        ClaimTicketNo,
        Weight,
        RatePerKilo,
        Charge,
        DateReceived,
        Status
    )

    VALUES(
        pCustomerID,
        pTicketNo,
        pWeight,
        pRate,
        vCharge,
        CURDATE(),
        'In Process'
    );

END $$

DELIMITER ;

